{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://willruggiano.github.io/starter-kit/schemas/TASKS.schema.json",
  "title": "Starter Kit Tasks",
  "type": "object",
  "additionalProperties": false,
  "required": ["tasks"],
  "properties": {
    "$schema": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/task"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "taskId": {
      "type": "string",
      "pattern": "^T-[0-9]{3}$"
    },
    "taskStatus": {
      "type": "string",
      "enum": [
        "planned",
        "ready",
        "in_progress",
        "implemented",
        "verified",
        "blocked",
        "done"
      ]
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "status",
        "allowed_paths",
        "acceptance_criteria",
        "verification"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/taskId"
        },
        "title": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "status": {
          "$ref": "#/$defs/taskStatus"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/taskId"
          },
          "uniqueItems": true
        },
        "allowed_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "acceptance_criteria": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "verification": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "owner": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "notes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      }
    }
  }
}
